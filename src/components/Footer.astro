---
const currentYear = new Date().getFullYear();
---

<!-- Footer Section Start -->
<div
  class="section footer-section footer-section-03"
  style="background-image: url(/assets/images/bg/footer-bg.jpg);"
>
  <div class="container">
    <!-- Footer Widget Wrap Start -->
    <div class="footer-widget-wrap">
      <div class="row">
        <div class="col-lg-3 col-sm-6">
          <!-- Footer Widget Start -->
          <div class="footer-widget-about">
            <a class="footer-logo" href="/" aria-label="DevsDoc Home">
              <img
                src="/dd-logo.png"
                alt="DevsDoc - Software Development Company Logo"
                id="footer-logo"
              />
            </a>
            <p>
              We are a software engineering partner helping businesses build new
              products, scale existing applications, and turn ideas into
              reliable software.
            </p>
            <div class="footer-social">
              <ul class="social">
                <li>
                  <a href="https://www.linkedin.com/company/devsdoc-technologies/" target="_blank" rel="noopener noreferrer" aria-label="Connect with us on LinkedIn"
                    ><i class="fab fa-linkedin-in"></i></a>
                </li>
              </ul>
            </div>
          </div>
          <!-- Footer Widget End -->
        </div>
        <div class="col-lg-3 col-sm-6">
          <!-- Footer Widget Start -->
          <div class="footer-widget">
            <h4 class="footer-widget-title">Useful Links</h4>
            <div class="widget-link">
              <ul class="link">
                <li><a href="/about">About us</a></li>
                <li><a href="/service">Our Services</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/privacy-policy">Privacy Policy</a></li>
              </ul>
            </div>
          </div>
          <!-- Footer Widget End -->
        </div>
        <div class="col-lg-3 col-sm-6">
          <!-- Footer Widget Start -->
          <div class="footer-widget">
            <h4 class="footer-widget-title">Our Services</h4>
            <div class="widget-link">
              <ul class="link">
                <li>
                  <a href="/data-engineering"
                    >Data Engineering and AI Strategy</a>
                </li>
                <li>
                  <a href="/web-application">Web Application Development</a>
                </li>
                <li>
                  <a href="/mobile-application"
                    >Mobile Application Development</a>
                </li>
                <li><a href="/cloud-devops">Cloud and DevOps</a></li>
              </ul>
            </div>
          </div>
          <!-- Footer Widget End -->
        </div>
        <div class="col-lg-3 col-sm-6">
          <!-- Footer Widget Start -->
          <div class="footer-widget">
            <h4 class="footer-widget-title">Contact Information</h4>
            <div class="widget-info">
              <ul>
                <li>
                  <div class="info-icon">
                    <i class="flaticon-phone-call"></i>
                  </div>
                  <div class="info-text">
                    <span><a href="tel:+447769222161">+44 7769 222161</a></span>
                  </div>
                </li>
                <li>
                  <div class="info-icon">
                    <i class="far fa-envelope-open"></i>
                  </div>
                  <div class="info-text">
                    <span
                      ><a href="mailto:contact@devsdoc.com"
                        >contact@devsdoc.com</a
                      ></span
                    >
                  </div>
                </li>
                <li>
                  <div class="info-icon">
                    <i class="flaticon-pin"></i>
                  </div>
                  <div class="info-text">
                    <span>13 S Park Drive, Ilford, England IG3 9AA, GB</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
          <!-- Footer Widget End -->
        </div>
      </div>
    </div>
    <!-- Footer Widget Wrap End -->
  </div>

  <!-- Footer Copyright Start -->
  <div class="footer-copyright-area">
    <div class="container">
      <div class="footer-copyright-wrap">
        <div class="row align-items-center">
          <div class="col-lg-12">
            <!-- Footer Copyright Text Start -->
            <div class="copyright-text text-center">
              <p>© Copyrights {currentYear} DevsDoc All rights reserved.</p>
            </div>
            <!-- Footer Copyright Text End -->
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Footer Copyright End -->
</div>
<!-- Footer Section End -->
